# nekobox backend 環境変数設定例
# このファイルを .env にコピーして値を設定してください
#
# 【ローカル開発の場合】
# 1. このファイルを backend/.env にコピー
# 2. NEKOBOX_CFG_PATH をプロジェクトルートの config/ ディレクトリの絶対パスに変更
# 3. NEKOBOX_DB_PATH に SQLite ファイルを置くディレクトリを指定
# 4. LM Studio を起動しておく
# 5. scripts_local/start_backend.ps1 を実行

# app.config が置かれているディレクトリ
# サンプル設定は project_root/config/ にあります
NEKOBOX_CFG_PATH=C:\dev\claude\nekobox\nekobox\config

# SQLite DB ファイルが置かれているディレクトリ (nekobox.sqlite3 が作成されます)
NEKOBOX_DB_PATH=C:\nekobox\data

# LM Studio のホスト・ポート
NEKOBOX_LMSTUDIO_HOST=127.0.0.1
NEKOBOX_LMSTUDIO_PORT=1234

# バインドアドレス (省略時は 127.0.0.1 = ローカルのみ)
# Docker コンテナ内では 0.0.0.0 に設定する
# NEKOBOX_BIND_HOST=127.0.0.1

# ログレベル (trace / debug / info / warn / error)
RUST_LOG=info
