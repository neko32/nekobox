[node name="Main" type="Node"]
script = ExtResource("1")

; ── 背景レイヤー ──────────────────────────────────────────────
[node name="BackgroundLayer" type="CanvasLayer" parent="."]
layer = 0

[node name="BackgroundRect" type="TextureRect" parent="BackgroundLayer"]
