offset_bottom = 800.0
stretch_mode = 0

; ── キャラクターレイヤー ─────────────────────────────────────
[node name="CharacterLayer" type="CanvasLayer" parent="."]
layer = 1

[node name="CharacterContainer" type="Node2D" parent="CharacterLayer"]
