; ── UI レイヤー ──────────────────────────────────────────────
[node name="UILayer" type="CanvasLayer" parent="."]
layer = 2

[node name="MainControl" type="Control" parent="UILayer"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

; セッションラベル（左上）
[node name="SessionLabel" type="Label" parent="UILayer/MainControl"]
layout_mode = 0
offset_left = 12.0
offset_top = 12.0
theme_override_colors/font_color = Color(1, 1, 1, 0.9)
theme_override_font_sizes/font_size = 20
text = "Session: ---"

; 時刻・日付ラベル（セッションラベルの下）
[node name="ClockLabel" type="Label" parent="UILayer/MainControl"]
layout_mode = 0
offset_left = 12.0
offset_top = 40.0
theme_override_colors/font_color = Color(1, 1, 1, 0.85)
theme_override_font_sizes/font_size = 16
text = ""

; チャットウィンドウ（画面下30%、半透明）
[node name="ChatWindow" type="PanelContainer" parent="UILayer/MainControl"]
